#!/bin/bash
# pip → uv pip wrapper. uv is ~10-100x faster than pip for installs.
#
# The sandbox runs with PIP_USER=1 + PYTHONUSERBASE=/home/sandbox/.local
# (off the s3fs mount — see images/sandbox/Dockerfile for the rationale).
# uv pip does not honor PIP_USER and rejects --user, so for the `install`
# subcommand we translate that intent into --target.
set -e

UV=/usr/local/bin/uv
VENV_PY=/opt/venv/bin/python

unset PIP_USER

if [[ "${1:-}" == "install" ]]; then
    shift
    filtered=()
    for arg in "$@"; do
        [[ "$arg" == "--user" ]] && continue
        filtered+=("$arg")
    done
    py_ver=$("$VENV_PY" -c 'import sys; print(f"python{sys.version_info.major}.{sys.version_info.minor}")')
    target="${PYTHONUSERBASE:-/home/sandbox/.local}/lib/$py_ver/site-packages"
    mkdir -p "$target"
    exec "$UV" pip install --python "$VENV_PY" --target "$target" "${filtered[@]}"
fi

exec "$UV" pip "$@" --python "$VENV_PY"
